# MeetGeek webhook secret (used for HMAC SHA256 verification; header x-mg-signature)
MEETGEEK_SECRET=your_webhook_secret_here

# MeetGeek API key (to fetch full meeting/transcript when webhook sends only meeting_id)
# Get from MeetGeek: Public API / Integrations. Used as: Authorization: Bearer MEETGEEK_API_KEY
MEETGEEK_API_KEY=
MEETGEEK_API_BASE=https://api.meetgeek.ai

# MongoDB connection string (Atlas or local). Run migrations on app startup or: python -m migrations.runner
# Atlas: add your IP in Atlas → Network Access. If SSL handshake fails (e.g. WSL2), set MONGODB_STANDARD_URI (see docs/mongodb-ssl-troubleshooting.md)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/
# Optional: use Atlas "Standard" connection string (Connect → Drivers → Standard) if SRV has SSL errors in WSL2
# MONGODB_STANDARD_URI=mongodb://ac-xxx-shard-00-00.xxxxx.mongodb.net:27017,ac-xxx-shard-00-01....net:27017,ac-xxx-shard-00-02....net:27017/?ssl=true&replicaSet=atlas-xxx&authSource=admin
MONGODB_DB_NAME=meetgeek
# Optional (dev only): MONGODB_TLS_INSECURE=1 to relax TLS verification

# OpenAI API key for transcript analysis (required only if ENABLE_AI_ENGINE=true)
OPENAI_API_KEY=your_openai_key
# Set to true to run AI analysis on transcripts (default: false; only raw transcript stored)
ENABLE_AI_ENGINE=false

# Server port
PORT=8000

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: public API key. If set, GET /meetings, /dashboard, etc. require X-API-Key or Authorization: Bearer <key>
# Leave empty to allow unauthenticated access to the API.
PUBLIC_API_KEY=
