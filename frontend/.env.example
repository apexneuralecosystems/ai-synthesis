# Backend API base URL (no trailing slash). All API calls use only this.
# Local dev:
#   VITE_API_BASE_URL=http://localhost:8000/api
#   Or same-origin proxy: VITE_API_BASE_URL=/api
# Production (also set in .env.production and Docker build-arg):
#   VITE_API_BASE_URL=https://backend.apexneurallabs.com/api
VITE_API_BASE_URL=http://localhost:8000/api
