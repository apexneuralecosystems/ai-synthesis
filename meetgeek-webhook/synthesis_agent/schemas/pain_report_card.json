{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pain Report Card",
  "type": "object",
  "required": ["report_card"],
  "properties": {
    "report_card": {
      "type": "object",
      "required": [
        "meta", "executive_summary", "pain_points", "data_signals",
        "stakeholder_assessment", "key_numbers", "open_questions",
        "hypothesis_updates", "call_type_specific_notes",
        "pain_validity_score", "pain_validity_rationale",
        "recommended_next_steps"
      ],
      "properties": {
        "meta": {
          "type": "object",
          "required": ["call_id", "call_type", "date", "duration_minutes", "participants", "interviewer", "transcript_file"],
          "properties": {
            "call_id": {"type": "string", "minLength": 1},
            "call_type": {"type": "string", "enum": ["CEO", "Operations", "Tech", "Survey"]},
            "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
            "duration_minutes": {"type": "number", "minimum": 0},
            "participants": {"type": "array", "items": {"type": "string"}, "minItems": 1},
            "interviewer": {"type": "string", "minLength": 1},
            "recording_file": {"type": ["string", "null"]},
            "transcript_file": {"type": "string", "minLength": 1}
          }
        },
        "executive_summary": {"type": "string", "minLength": 10},
        "pain_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id", "title", "description", "severity", "severity_rationale",
              "source_quotes", "cost_estimate", "affected_stakeholders",
              "current_workaround", "agent_opportunity"
            ],
            "properties": {
              "id": {"type": "string", "pattern": "^P\\d+$"},
              "title": {"type": "string", "minLength": 3},
              "description": {"type": "string", "minLength": 10},
              "severity": {"type": "number", "minimum": 1, "maximum": 10},
              "severity_rationale": {"type": "string", "minLength": 10},
              "source_quotes": {
                "type": "array",
                "items": {"type": "string", "minLength": 5},
                "minItems": 1
              },
              "cost_estimate": {
                "type": "object",
                "required": ["amount", "confidence", "method", "basis"],
                "properties": {
                  "amount": {"type": "string", "minLength": 1},
                  "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
                  "method": {"type": "string", "enum": ["direct", "derived", "guesstimate"]},
                  "basis": {"type": "string", "minLength": 1}
                }
              },
              "affected_stakeholders": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "current_workaround": {"type": "string", "minLength": 1},
              "agent_opportunity": {"type": "string", "minLength": 1}
            }
          }
        },
        "data_signals": {
          "type": "object",
          "required": ["systems_mentioned", "data_sources_identified", "access_feasibility", "access_notes"],
          "properties": {
            "systems_mentioned": {"type": "array", "items": {"type": "string"}},
            "data_sources_identified": {"type": "array", "items": {"type": "string"}},
            "access_feasibility": {"type": "string", "enum": ["easy", "moderate", "complex"]},
            "access_notes": {"type": "string", "minLength": 1}
          }
        },
        "stakeholder_assessment": {
          "type": "object",
          "required": [
            "enthusiasm_level", "enthusiasm_rationale", "trust_level", "trust_rationale",
            "decision_authority", "decision_authority_notes", "champion_identified", "resistance_risks"
          ],
          "properties": {
            "enthusiasm_level": {"type": "number", "minimum": 1, "maximum": 10},
            "enthusiasm_rationale": {"type": "string", "minLength": 1},
            "trust_level": {"type": "number", "minimum": 1, "maximum": 10},
            "trust_rationale": {"type": "string", "minLength": 1},
            "decision_authority": {"type": "string", "enum": ["sole", "committee", "influencer only"]},
            "decision_authority_notes": {"type": "string", "minLength": 1},
            "champion_identified": {"type": "string", "minLength": 1},
            "resistance_risks": {"type": "string", "minLength": 1}
          }
        },
        "key_numbers": {"type": "object"},
        "open_questions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "hypothesis_updates": {
          "type": "object",
          "required": ["confirmed", "invalidated", "new"],
          "properties": {
            "confirmed": {"type": "array", "items": {"type": "string"}},
            "invalidated": {"type": "array", "items": {"type": "string"}},
            "new": {"type": "array", "items": {"type": "string"}}
          }
        },
        "call_type_specific_notes": {"type": "object"},
        "pain_validity_score": {"type": "number", "minimum": 1, "maximum": 10},
        "pain_validity_rationale": {"type": "string", "minLength": 10},
        "recommended_next_steps": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      }
    }
  }
}
